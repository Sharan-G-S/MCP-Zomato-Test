# =============================================================
# Zomato MCP Chat — Environment Configuration
# =============================================================

# Gemini API Key (primary)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini API Key (secondary backup, optional)
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# Groq API Key (fallback)
GROQ_API_KEY=your_groq_api_key_here

# Server Port (optional, defaults to 3000)
PORT=3000

# Zomato MCP Server URL (do not change unless Zomato updates it)
# ZOMATO_MCP_URL=https://mcp-server.zomato.com/mcp

# OAuth Callback Port (do not change unless port 9876 is occupied)
# OAUTH_CALLBACK_PORT=9876
